{
  "name": "@editora/content-rules",
  "version": "1.0.0",
  "description": "Native content rules plugin for Editora with realtime linting, required sections, and readability checks",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build"
  },
  "keywords": [
    "editora",
    "content-rules",
    "lint",
    "writing-guidelines",
    "readability"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ajaykr089/Editora.git"
  },
  "license": "MIT",
  "dependencies": {
    "@editora/core": "^1.0.7"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.esm.js"
    }
  }
}
