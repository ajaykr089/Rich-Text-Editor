{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@editora/core": ["../core/index.d.ts"],
      "@editora/core/*": ["../core/index.d.ts"],
      "@editora/light-code-editor": ["../light-code-editor/dist/index.d.ts"],
      "@editora/light-code-editor/*": ["../light-code-editor/dist/*"],
      "@editora/toast": ["../editora-toast/src/index.d.ts"],
      "@editora/toast/*": ["../editora-toast/src/*"],
      "@editora/themes": ["../themes/index.d.ts"],
      "@editora/themes/*": ["../themes/src/*"]
    },
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*", "*/src/**/*"],
  "exclude": ["dist", "**/*.test.ts"]
}
