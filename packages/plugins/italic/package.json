{
  "name": "@editora/plugin-italic",
  "version": "1.0.3",
  "description": "Italic plugin for Rich Text Editor",
  "authors": [
    "Ajay Kumar <ajaykr089@gmail.com>"
  ],
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@editora/core": "^1.0.6"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.esm.js"
    }
  }
