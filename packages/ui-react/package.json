{
  "name": "@editora/ui-react",
  "version": "0.1.4",
  "description": "React wrappers and hooks for Web Components in the Editora UI ecosystem",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.esm.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:tsc": "npm --prefix ../ui-core run build:tsc && tsc -p . --emitDeclarationOnly --noEmit false --outDir dist",
    "build": "npm --prefix ../ui-core run build:tsc && vite build && npm run build:tsc",
    "dev": "vite build --watch",
    "dev:examples": "vite --config examples/vite.config.ts",
    "build:examples": "vite build --config examples/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "jsdom": "^22.1.0",
    "typescript": "^5.0.0",
    "vite": "^4.5.14",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "react": ">=16.8 <21",
    "react-dom": ">=16.8 <21"
  },
  "dependencies": {
    "@editora/toast": "^2.0.4",
    "@editora/ui-core": "^0.1.3"
  },
  "keywords": [
    "editora",
    "editora ui ecosystem",
    "ui-react",
    "react",
    "web-components",
    "design-system",
    "typescript",
    "admin-ui",
    "component-library"
  ],
  "author": "Ajay Kumar <ajaykr089@gmail.com>",
  "license": "MIT",
  "sideEffects": true,
  "gitHead": "80e0808ae4909de63b8e0f1dd915b06b33a8ed44"
}
