{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react",
    "baseUrl": ".",
    "paths": {
      "@editora/ui-core": ["../ui-core/dist/index", "../ui-core/src/index.ts"],
      "@editora/ui-core/*": ["../ui-core/dist/*", "../ui-core/src/*"],
      "@editora/toast": ["../editora-toast/dist/index", "../editora-toast/src/index.ts"],
      "@editora/toast/*": ["../editora-toast/dist/*", "../editora-toast/src/*"]
    },
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src"]
}
